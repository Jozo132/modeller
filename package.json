{
  "name": "modeller",
  "version": "1.0.0",
  "description": "Multipurpose parametric CAD modelling library — 3D viewer, 2D viewer, mesher, converter and tester in one. Usable as an NPM package for both Node.js (backend) and browser (frontend) environments.",
  "keywords": [
    "cad",
    "modeller",
    "3d",
    "2d",
    "parametric",
    "nurbs",
    "brep",
    "csg",
    "mesh",
    "sketch",
    "extrude",
    "revolve",
    "fillet",
    "chamfer",
    "viewer",
    "converter",
    "step",
    "dxf",
    "cmod"
  ],
  "author": "Jozo132 <jozo132@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "./js/index.js",
  "scripts": {
    "start": "npx serve .",
    "test:parametric": "node test-parametric.js",
    "test:workflow": "node tests/test-workflow-recordings.js",
    "test:cmod": "node tests/test-cmod-import-export.js",
    "test:history": "node tests/test-history-replay.js",
    "test:editor": "node tests/test-feature-editor-ux.js",
    "test:parity": "node tests/test-evaluator-parity.js",
    "test:cache": "node tests/test-cache-stores.js",
    "test:incremental": "node tests/test-incremental-tessellation.js",
    "test:ir": "node tests/test-ir-determinism.js",
    "test:exact-revolve": "node tests/test-exact-revolve.js",
    "test:stable-hash": "node tests/test-stable-hash.js",
    "lint:evaluator": "node tools/check-evaluator-bypass.js",
    "cli": "node tools/cad-cli.mjs",
    "render:cmod": "node tools/render-cmod.js",
    "asbuild:debug": "asc assembly/index.ts --target debug",
    "asbuild:release": "asc assembly/index.ts --target release",
    "asbuild": "npm run asbuild:debug && npm run asbuild:release",
    "test": "node tests && node tests/test-multi-body-chamfer-fillet.js && node tests/test-coplanar-merge.js && node tests/test-face-selection.js && node tests/test-geometry-persistence.js && node tests/test-incremental-tessellation.js && node tests/test-interaction-recorder.js && node tests/test-multi-sketch-planes.js && node tests/test-exact-revolve.js && node tests/test-stable-hash.js && node tests/test-ui-workflow.js && node tests/test-workflow-recordings.js && node tests/test-cmod-import-export.js && node tests/test-history-replay.js && node tests/test-feature-editor-ux.js && node tests/test-api-migration.js && node tests/test-fallback-warn-once.js && node tests/test-feature-pipeline.js && node tests/test-toolkit.js",
    "test:pipeline": "node tests/test-feature-pipeline.js",
    "test:toolkit": "node tests/test-toolkit.js",
    "test:migration": "node tests/test-api-migration.js",
    "test:warn-once": "node tests/test-fallback-warn-once.js",
    "test:workers": "node tests/test-worker-dispatcher.js",
    "test:telemetry": "node tests/test-telemetry.js",
    "test:assembly": "node tests/test-assembly-design.js",
    "test:nist-step": "node tests/test-step-import-nist.js",
    "test:nist-step:gate": "node tests/test-step-import-nist.js --regression-gate --allow-failures",
    "test:nist-step:scorecard": "node tests/test-step-import-nist.js --write-scorecard tests/step-import-nist-scorecard.md --allow-failures",
    "test:nist-step:roundtrip": "node tests/test-step-roundtrip-nist.js",
    "test:e2e": "npx playwright test",
    "download": "node tests/download-public-nist-samples.js",
    "report:nurbs-variants": "node tests/report-nurbs-variants.js"
  },
  "files": [
    "js/",
    "packages/",
    "build/",
    "README.md",
    "LICENSE",
    "ARCHITECTURE.md"
  ],
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.68",
    "assemblyscript": "^0.28.9",
    "pdfkit": "^0.18.0"
  },
  "exports": {
    ".": {
      "import": "./js/index.js"
    },
    "./cad": {
      "import": "./js/cad/index.js"
    },
    "./render": {
      "import": "./js/render/index.js"
    },
    "./cmod": {
      "import": "./js/cmod.js"
    },
    "./logger": {
      "import": "./js/logger.js"
    },
    "./wasm": {
      "import": "./build/release.js",
      "types": "./build/release.d.ts"
    },
    "./flags": {
      "import": "./js/featureFlags.js"
    },
    "./ir": {
      "import": "./js/ir/index.js"
    },
    "./cache": {
      "import": "./js/cache/index.js"
    },
    "./workers": {
      "import": "./js/workers/index.js"
    },
    "./telemetry": {
      "import": "./js/telemetry.js"
    }
  }
}
